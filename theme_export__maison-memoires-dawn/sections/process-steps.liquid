{{ 'section-process-steps.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="process-steps color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="process-steps__header">
      {%- if section.settings.caption != blank -%}
        <p class="process-steps__eyebrow">{{ section.settings.caption | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="process-steps__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="process-steps__intro">{{ section.settings.intro | escape }}</p>
      {%- endif -%}
    </div>

    <div class="process-steps__grid">
      {%- for block in section.blocks -%}
        <article class="process-step" {{ block.shopify_attributes }}>
          <span class="process-step__index">{{ forloop.index }}</span>
          {%- if block.settings.title != blank -%}
            <h3 class="process-step__title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="process-step__text">{{ block.settings.text | escape }}</p>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Process steps",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Comment ça fonctionne"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Un parcours simple, rassurant et pensé pour avancer sans vous presser."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Vous choisissez votre format, vous l'ajoutez au panier, puis vous finalisez tranquillement la personnalisation avant le paiement."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Étape"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Expliquez cette étape en une ou deux phrases rassurantes."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Process steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Choisissez votre format audio",
            "text": "Voix enregistrée, création musicale sur mesure ou formule mixte selon l'émotion que vous souhaitez offrir."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Ajoutez votre souvenir au panier",
            "text": "Vous réservez d'abord le format choisi, sans avoir à remplir immédiatement tous les détails."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Finalisez la personnalisation",
            "text": "Depuis le panier, vous ajoutez votre fichier audio, votre brief créatif et les précisions utiles selon l'option choisie."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Nous créons sous 48h",
            "text": "Pour l'audio créé par IA, vous recevez un aperçu avant production afin de valider le rendu final."
          }
        }
      ]
    }
  ]
}
{% endschema %}

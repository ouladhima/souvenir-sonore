{{ 'section-faq-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="faq-premium color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="faq-premium__header">
      {%- if section.settings.caption != blank -%}
        <p class="faq-premium__eyebrow">{{ section.settings.caption | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="faq-premium__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="faq-premium__intro">{{ section.settings.intro | escape }}</p>
      {%- endif -%}
    </div>

    <div class="faq-premium__list">
      {%- for block in section.blocks -%}
        {%- if block.settings.question != blank and block.settings.answer != blank -%}
          <details
            class="faq-premium__item"
            {{ block.shopify_attributes }}
            {% if section.settings.open_first_question and forloop.first %}
              open
            {% endif %}
          >
            <summary class="faq-premium__summary">
              <h3 class="faq-premium__question">{{ block.settings.question | escape }}</h3>
              <span class="faq-premium__icon svg-wrapper">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </summary>
            <div class="faq-premium__answer rte">{{ block.settings.answer }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.enable_schema -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {%- assign schema_first = true -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.question != blank and block.settings.answer != blank -%}
              {%- unless schema_first -%},{%- endunless -%}
              {
                "@type": "Question",
                "name": {{ block.settings.question | strip_html | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ block.settings.answer | strip_html | json }}
                }
              }
              {%- assign schema_first = false -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      }
    </script>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Premium FAQ",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "FAQ"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Les réponses aux questions que l'on se pose avant d'offrir un souvenir si personnel."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Cette FAQ est pensée pour rendre le parcours limpide, du choix du format jusqu'à la finalisation de la personnalisation dans le panier."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "open_first_question",
      "label": "Open first question",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_schema",
      "label": "Enable FAQ schema",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 44
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Votre question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Votre réponse.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium FAQ",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "Quand vais-je transmettre mon fichier audio ou mon brief ?",
            "answer": "<p>Juste après l'ajout au panier. Le panier devient l'espace où vous finalisez tranquillement les éléments de personnalisation avant de passer au paiement.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Que puis-je envoyer comme fichier audio ?",
            "answer": "<p>Vous pouvez partager un message vocal, une archive sonore, un extrait enregistré sur téléphone ou tout fichier audio exploitable pour la création.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Comment fonctionne la création sur mesure ?",
            "answer": "<p>Vous décrivez votre intention créative dans le panier. Nous composons ensuite une proposition musicale personnalisée pensée pour votre histoire et votre émotion.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Recevrai-je un aperçu avant la fabrication ?",
            "answer": "<p>Oui. Pour l'audio créé par IA, vous recevez un aperçu avant production afin d'écouter, confirmer et valider le rendu final.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Sous quel délai mon projet est-il préparé ?",
            "answer": "<p>La création est préparée sous 48h dans la majorité des cas, hors périodes exceptionnelles ou besoins de retouches plus poussées.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Puis-je ajouter des précisions à ma commande ?",
            "answer": "<p>Oui. La zone Notes complémentaires vous permet d'ajouter un contexte utile, une attention particulière ou un détail qui aidera notre équipe à personnaliser le rendu.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign occasions = section.settings.occasions | newline_to_br | split: '<br />'
-%}

<section class="product-occasions-marquee color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.caption != blank -%}
      <p class="product-occasions-marquee__caption">{{ section.settings.caption | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="product-occasions-marquee__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <div class="product-occasions-marquee__viewport" role="region" aria-label="{{ section.settings.accessibility_label | escape }}">
      <ul class="product-occasions-marquee__track" aria-hidden="false">
        {%- for occasion in occasions -%}
          {%- assign occasion_text = occasion | strip -%}
          {%- if occasion_text != blank -%}
            <li>{{ occasion_text }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
      <ul class="product-occasions-marquee__track" aria-hidden="true">
        {%- for occasion in occasions -%}
          {%- assign occasion_text = occasion | strip -%}
          {%- if occasion_text != blank -%}
            <li>{{ occasion_text }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    {%- if section.settings.coda != blank -%}
      <p class="product-occasions-marquee__coda">{{ section.settings.coda | escape }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .product-occasions-marquee {
    text-align: center;
  }

  .product-occasions-marquee__caption {
    margin: 0 0 1rem;
    color: rgba(var(--color-foreground), 0.58);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .product-occasions-marquee__heading {
    margin: 0 auto 3rem;
    max-width: 78rem;
  }

  .product-occasions-marquee__viewport {
    --occasion-line-height: clamp(4.4rem, 6vw, 5.6rem);
    --occasion-visible-rows: 5;
    --occasion-track-duration: 38s;
    position: relative;
    width: 100%;
    max-width: 60rem;
    height: calc(var(--occasion-line-height) * var(--occasion-visible-rows));
    margin: 0 auto;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 18%, #000 82%, transparent 100%);
    mask-image: linear-gradient(180deg, transparent 0%, #000 18%, #000 82%, transparent 100%);
  }

  .product-occasions-marquee__track {
    display: block;
    list-style: none;
    margin: 0;
    padding: 0;
    color: rgb(var(--color-foreground));
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 2.6vw, 2.8rem);
    font-style: var(--font-heading-style);
    letter-spacing: 0;
    animation: productOccasionsScroll var(--occasion-track-duration) linear infinite;
    will-change: transform;
  }

  .product-occasions-marquee__track li {
    display: flex;
    align-items: center;
    justify-content: center;
    height: var(--occasion-line-height);
    color: inherit;
    text-align: center;
  }

  @keyframes productOccasionsScroll {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(0, -100%, 0);
    }
  }

  .product-occasions-marquee__viewport:hover .product-occasions-marquee__track,
  .product-occasions-marquee__viewport:focus-within .product-occasions-marquee__track {
    animation-play-state: paused;
  }

  .product-occasions-marquee__coda {
    max-width: 48rem;
    margin: 3.2rem auto 0;
    color: rgba(var(--color-foreground), 0.62);
    font-family: var(--font-heading-family);
    font-size: clamp(1.7rem, 2.1vw, 2.1rem);
    font-style: italic;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .product-occasions-marquee__viewport {
      --occasion-line-height: clamp(3.6rem, 11vw, 4.4rem);
      --occasion-visible-rows: 4;
      max-width: 38rem;
    }

    .product-occasions-marquee__track {
      font-size: clamp(1.8rem, 5.6vw, 2.4rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-occasions-marquee__viewport {
      height: auto;
      overflow: visible;
      -webkit-mask-image: none;
      mask-image: none;
    }

    .product-occasions-marquee__track {
      animation: none;
    }

    .product-occasions-marquee__track + .product-occasions-marquee__track {
      display: none;
    }
  }
{% endstylesheet %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Occasions défilantes",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Surtitre",
      "default": "Pour quelles occasions"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titre",
      "default": "Un souvenir audio pour les moments qui comptent."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Taille du titre",
      "options": [
        {
          "value": "h2",
          "label": "Petit"
        },
        {
          "value": "h1",
          "label": "Moyen"
        },
        {
          "value": "h0",
          "label": "Grand"
        }
      ],
      "default": "h1"
    },
    {
      "type": "textarea",
      "id": "occasions",
      "label": "Occasions",
      "default": "Pour un anniversaire\nPour dire je t'aime\nPour une naissance\nPour un mariage\nPour la fête des mères\nPour la fête des pères\nPour des fiançailles\nPour un baptême\nPour Noël\nPour la Saint-Valentin\nPour un départ à la retraite\nPour un anniversaire de mariage\nPour annoncer une grande nouvelle\nPour célébrer une amitié\nPour rendre hommage à un proche\nPour dire merci\nPour marquer une réussite\nPour un déménagement"
    },
    {
      "type": "text",
      "id": "coda",
      "label": "Phrase finale",
      "default": "Ou simplement... pour ne rien oublier."
    },
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Libellé d'accessibilité",
      "default": "Pour quelles occasions offrir une cassette audio personnalisée"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "Occasions défilantes"
    }
  ]
}
{% endschema %}

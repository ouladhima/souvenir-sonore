{{ 'section-maison-homepage.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-maison-homepage.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign product_handle = settings.audio_keepsake_product_handle | default: 'ecrin-sonore' | strip
  capture product_url
    render 'audio-keepsake-product-url'
  endcapture
  assign product_url = product_url | strip

  if section.settings.home_product != blank
    assign product_handle = section.settings.home_product.handle
    assign product_url = section.settings.home_product.url
  elsif all_products[product_handle] != blank
    assign product_handle = all_products[product_handle].handle
    assign product_url = all_products[product_handle].url
  elsif collections['all'].products.first != blank
    assign product_handle = collections['all'].products.first.handle
  endif
-%}

{%- capture frame_urls -%}
  [
    {%- for i in (1..96) -%}
      {%- assign frame_number = i | prepend: '0000' | slice: -4, 4 -%}
      {{- 'maison-home-frame-' | append: frame_number | append: '.webp' | asset_url | json -}}
      {%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
{%- endcapture -%}

<div class="maison-homepage">
  <section class="maison-homepage__hero maison-homepage__hero--centered" id="maison-homepage-hero">
    <div class="page-width maison-homepage__hero-shell">
      <div class="maison-homepage__hero-copy">
        <h1 class="maison-homepage__hero-title">
          Certains souvenirs se regardent.<br>
          Celui-ci s&rsquo;&eacute;coute.
        </h1>
        <p class="maison-homepage__hero-lead">
          Un message, une voix, un moment&hellip; &agrave; garder pour toujours.
        </p>

        <div class="maison-homepage__actions maison-homepage__actions--centered">
          <a class="button button--primary" href="{{ product_url }}" data-product-handle="{{ product_handle }}">
            Cr&eacute;er mon souvenir
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="maison-homepage__section maison-homepage__brand-promise">
    <div class="page-width">
      <p class="maison-homepage__statement">
        Chez Maison M&eacute;moire, nous ne cr&eacute;ons pas des objets.<br>
        Nous capturons des moments que l&rsquo;on ne veut pas oublier.
      </p>
    </div>
  </section>

  <section class="maison-homepage__section maison-homepage__problem">
    <div class="page-width">
      <p class="maison-homepage__statement maison-homepage__statement--quiet">
        Les mots se perdent.<br>
        Les souvenirs s&rsquo;effacent.<br>
        Et les instants les plus pr&eacute;cieux passent trop vite.
      </p>
    </div>
  </section>

  <section class="maison-homepage__section maison-homepage__object">
    <div class="page-width maison-homepage__object-shell">
      <div class="maison-homepage__object-copy">
        <h2 class="maison-homepage__object-title">
          Nous avons imagin&eacute; un objet simple.<br>
          Un &eacute;crin. Une cassette.<br>
          Et un message qui ne dispara&icirc;t jamais.
        </h2>

        <a class="button button--secondary" href="{{ product_url }}" data-product-handle="{{ product_handle }}">
          D&eacute;couvrir la cassette
        </a>
      </div>

      <figure class="maison-homepage__object-media">
        <img
          src="{{ 'maison-home-showcase-2.png' | asset_url }}"
          alt="Coffret cadeau personnalis&eacute; avec une pr&eacute;sentation &eacute;ditoriale raffin&eacute;e"
          width="1536"
          height="1024"
          loading="lazy"
          decoding="async"
        >
      </figure>
    </div>
  </section>

  <section class="maison-homepage__section maison-homepage__sequence" id="maison-homepage-sequence" aria-labelledby="maison-homepage-sequence-title">
    <div class="page-width">
      <div
        class="maison-homepage__sequence-shell"
        data-scroll-sequence
        data-frame-count="96"
        data-frame-pad="4"
        data-mobile-step="2"
        data-hold-ratio="0.84"
      >
        <script type="application/json" data-sequence-urls>{{ frame_urls | strip }}</script>

        <div class="maison-homepage__sequence-sticky">
          <div class="maison-homepage__sequence-copy">
            <h2 id="maison-homepage-sequence-title">Ouvrez. &Eacute;coutez. Ressentez.</h2>
            <p>Un moment. Une voix. Un souvenir.</p>
          </div>

          <div class="maison-homepage__sequence-stage" data-sequence-stage>
            <div class="maison-homepage__sequence-halo" aria-hidden="true"></div>
            <canvas
              class="maison-homepage__sequence-canvas"
              data-sequence-canvas
              aria-hidden="true"
            ></canvas>
            <img
              class="maison-homepage__sequence-fallback"
              data-sequence-fallback
              src="{{ 'maison-home-frame-0001.webp' | asset_url }}"
              alt="Ouverture du coffret et r&eacute;v&eacute;lation de la cassette audio personnalis&eacute;e"
              width="1600"
              height="1200"
              loading="lazy"
              decoding="async"
            >
            <div class="maison-homepage__sequence-cta">
              <a class="button button--primary" href="{{ product_url }}" data-product-handle="{{ product_handle }}">
                Cr&eacute;er mon souvenir
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="maison-homepage__section maison-homepage__ritual">
    <div class="page-width">
      <ol class="maison-homepage__ritual-list" data-ritual-reveal aria-label="Le rituel d&rsquo;une &eacute;coute">
        <li><span class="maison-homepage__ritual-word">Ouvrir</span></li>
        <li><span class="maison-homepage__ritual-word">Appuyer sur play</span></li>
        <li><span class="maison-homepage__ritual-word">Ressentir</span></li>
      </ol>
    </div>
  </section>

  {%- if section.settings.ai_audio_1_url != blank or section.settings.ai_audio_2_url != blank -%}
  <section class="maison-homepage__section maison-homepage__audio-preview" id="maison-homepage-audio-preview">
    <div class="page-width">
      <div class="maison-homepage__section-heading">
        <h2>{{ section.settings.ai_audio_heading | default: 'Quelques instants&hellip; &agrave; &eacute;couter' }}</h2>
        <p>{{ section.settings.ai_audio_subtext | default: 'Des mots simples. Des voix vraies. Des souvenirs qui restent.' }}</p>
      </div>

      <div class="maison-homepage__audio-cards">
        {%- if section.settings.ai_audio_1_url != blank -%}
          <div class="maison-homepage__audio-card">
            <div class="maison-homepage__audio-card-visual" aria-hidden="true">
              <span class="maison-homepage__audio-card-caption">Maison M&eacute;moire</span>
              <span class="maison-homepage__audio-card-window"></span>
              <span class="maison-homepage__audio-card-reel maison-homepage__audio-card-reel--left"></span>
              <span class="maison-homepage__audio-card-reel maison-homepage__audio-card-reel--right"></span>
            </div>
            <div class="maison-homepage__audio-card-meta">
              <p class="maison-homepage__audio-card-label">{{ section.settings.ai_audio_1_label | default: 'Cr&eacute;ation 1' }}</p>
              {%- if section.settings.ai_audio_1_desc != blank -%}
                <p class="maison-homepage__audio-card-desc">{{ section.settings.ai_audio_1_desc }}</p>
              {%- endif -%}
            </div>
            <audio class="maison-homepage__audio-player" controls preload="none">
              <source src="{{ section.settings.ai_audio_1_url }}" type="audio/mpeg">
            </audio>
          </div>
        {%- endif -%}

        {%- if section.settings.ai_audio_2_url != blank -%}
          <div class="maison-homepage__audio-card">
            <div class="maison-homepage__audio-card-visual" aria-hidden="true">
              <span class="maison-homepage__audio-card-caption">Maison M&eacute;moire</span>
              <span class="maison-homepage__audio-card-window"></span>
              <span class="maison-homepage__audio-card-reel maison-homepage__audio-card-reel--left"></span>
              <span class="maison-homepage__audio-card-reel maison-homepage__audio-card-reel--right"></span>
            </div>
            <div class="maison-homepage__audio-card-meta">
              <p class="maison-homepage__audio-card-label">{{ section.settings.ai_audio_2_label | default: 'Cr&eacute;ation 2' }}</p>
              {%- if section.settings.ai_audio_2_desc != blank -%}
                <p class="maison-homepage__audio-card-desc">{{ section.settings.ai_audio_2_desc }}</p>
              {%- endif -%}
            </div>
            <audio class="maison-homepage__audio-player" controls preload="none">
              <source src="{{ section.settings.ai_audio_2_url }}" type="audio/mpeg">
            </audio>
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>
  {%- endif -%}

  <section class="maison-homepage__section maison-homepage__occasions">
    <div class="page-width">
      {%- assign occasions = 'Pour un anniversaire|Pour dire je t&rsquo;aime|Pour une naissance|Pour un mariage|Pour la f&ecirc;te des m&egrave;res|Pour la f&ecirc;te des p&egrave;res|Pour des fian&ccedil;ailles|Pour un bapt&ecirc;me|Pour No&euml;l|Pour la Saint-Valentin|Pour un d&eacute;part &agrave; la retraite|Pour un anniversaire de mariage|Pour annoncer une grande nouvelle|Pour c&eacute;l&eacute;brer une amiti&eacute;|Pour rendre hommage &agrave; un proche|Pour dire merci|Pour marquer une r&eacute;ussite|Pour un d&eacute;m&eacute;nagement' | split: '|' -%}

      <div class="maison-homepage__occasions-viewport" role="region" aria-label="Pour quelles occasions">
        <ul class="maison-homepage__occasions-track" aria-hidden="false">
          {%- for occasion in occasions -%}
            <li>{{ occasion }}</li>
          {%- endfor -%}
        </ul>
        <ul class="maison-homepage__occasions-track" aria-hidden="true">
          {%- for occasion in occasions -%}
            <li>{{ occasion }}</li>
          {%- endfor -%}
        </ul>
      </div>

      <p class="maison-homepage__occasions-coda">Ou simplement&hellip; pour ne rien oublier.</p>
    </div>
  </section>

  <script>
    (function () {
      var ritual = document.querySelector('[data-ritual-reveal]');
      if (!ritual) return;
      if (!('IntersectionObserver' in window)) {
        ritual.classList.add('is-revealed');
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.45 });
      io.observe(ritual);
    })();
  </script>

  <section class="maison-homepage__section maison-homepage__faq" id="maison-homepage-faq">
    <div class="page-width maison-homepage__faq-layout">
      <div class="maison-homepage__heading-group">
        <h2>Quelques pr&eacute;cisions, si besoin.</h2>
      </div>

      <div class="maison-homepage__faq-items">
        <details class="maison-homepage__faq-item">
          <summary>Comment fonctionne la chanson sur mesure&nbsp;?</summary>
          <p>
            Vous partagez l&rsquo;intention, l&rsquo;histoire et l&rsquo;&eacute;motion &agrave; transmettre. Nous composons
            ensuite une proposition musicale personnalis&eacute;e pens&eacute;e pour votre moment.
          </p>
        </details>
        <details class="maison-homepage__faq-item">
          <summary>Puis-je &eacute;couter avant la production&nbsp;?</summary>
          <p>
            Oui. Vous recevez un aper&ccedil;u avant fabrication afin d&rsquo;&eacute;couter, confirmer et valider le
            rendu final.
          </p>
        </details>
        <details class="maison-homepage__faq-item">
          <summary>Le coffret est-il pr&ecirc;t &agrave; offrir&nbsp;?</summary>
          <p>
            Oui. Le souvenir est pens&eacute; comme un objet cadeau premium, avec une pr&eacute;sentation soign&eacute;e
            et une finition con&ccedil;ue pour &ecirc;tre offerte d&egrave;s r&eacute;ception.
          </p>
        </details>
      </div>
    </div>

    <div class="page-width">
      <div class="maison-homepage__cta">
        <h2>Offrir plus qu&rsquo;un cadeau.</h2>
        <p>Cr&eacute;er un souvenir &agrave; &eacute;couter.</p>
        <div class="maison-homepage__actions maison-homepage__actions--centered">
          <a class="button button--primary" href="{{ product_url }}" data-product-handle="{{ product_handle }}">
            Cr&eacute;er mon souvenir
          </a>
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Maison Homepage",
  "settings": [
    {
      "type": "product",
      "id": "home_product",
      "label": "Produit des CTA"
    },
    {
      "type": "header",
      "content": "Exemples audio"
    },
    {
      "type": "text",
      "id": "ai_audio_heading",
      "label": "Titre de la section",
      "default": "Quelques instants… à écouter"
    },
    {
      "type": "text",
      "id": "ai_audio_subtext",
      "label": "Sous-titre",
      "default": "Des mots simples. Des voix vraies. Des souvenirs qui restent."
    },
    {
      "type": "text",
      "id": "ai_audio_1_label",
      "label": "Encart 1 — Titre",
      "default": "Ambiance romantique"
    },
    {
      "type": "url",
      "id": "ai_audio_1_url",
      "label": "Encart 1 — Lien audio (Shopify CDN)"
    },
    {
      "type": "text",
      "id": "ai_audio_1_desc",
      "label": "Encart 1 — Description courte",
      "default": "Composition douce et intime pour un anniversaire ou une déclaration."
    },
    {
      "type": "text",
      "id": "ai_audio_2_label",
      "label": "Encart 2 — Titre",
      "default": "Mélodie de naissance"
    },
    {
      "type": "url",
      "id": "ai_audio_2_url",
      "label": "Encart 2 — Lien audio (Shopify CDN)"
    },
    {
      "type": "text",
      "id": "ai_audio_2_desc",
      "label": "Encart 2 — Description courte",
      "default": "Berceuse moderne pour célébrer l'arrivée d'un enfant."
    }
  ],
  "presets": [
    {
      "name": "Maison Homepage"
    }
  ]
}
{% endschema %}

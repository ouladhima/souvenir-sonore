{% comment %}
  Renders one part of the premium audio keepsake teaser inside the product form.

  Accepts:
  - product: Product object
  - panel_group: primary | secondary
{% endcomment %}
{%- liquid
  assign panel_group = panel_group | default: 'primary'
  assign audio_option_name = settings.audio_option_name | default: 'Type audio'
  assign duration_option_name = settings.duration_option_name | default: 'Durée'
  assign packaging_option_name = settings.packaging_option_name | default: 'Coffret'
  assign voice_audio_value = settings.voice_audio_value | default: 'Votre enregistrement'
  assign ai_audio_value = settings.ai_audio_value | default: "Une musique composée par nos soins ( jusqu'à 3 propositions)"
  assign voice_music_value = settings.voice_music_value | default: 'Votre enregistrement avec une musique composée'

  assign selected_audio_value = ''
  assign selected_duration = ''
  assign selected_packaging = ''
  assign fallback_duration = ''
  assign fallback_packaging = ''

  for option in product.options_with_values
    if option.name == audio_option_name and selected_audio_value == blank
      assign selected_audio_value = option.selected_value
    elsif option.name == duration_option_name and selected_duration == blank
      assign selected_duration = option.selected_value
    elsif option.name == packaging_option_name and selected_packaging == blank
      assign selected_packaging = option.selected_value
    elsif fallback_duration == blank
      assign fallback_duration = option.selected_value
    elsif fallback_packaging == blank
      assign fallback_packaging = option.selected_value
    endif
  endfor

  if selected_duration == blank
    assign selected_duration = fallback_duration
  endif

  if selected_packaging == blank
    assign selected_packaging = fallback_packaging
  endif

  assign normalized_audio_value = selected_audio_value | strip | downcase
  assign normalized_voice_value = voice_audio_value | strip | downcase
  assign normalized_ai_value = ai_audio_value | strip | downcase
  assign normalized_voice_music_value = voice_music_value | strip | downcase

  assign initial_audio_mode = ''

  if normalized_audio_value == normalized_voice_value
    assign initial_audio_mode = 'voice'
  elsif normalized_audio_value == normalized_ai_value
    assign initial_audio_mode = 'ai'
  elsif normalized_audio_value == normalized_voice_music_value
    assign initial_audio_mode = 'voice_music'
  elsif normalized_audio_value contains 'voix' and normalized_audio_value contains 'musique'
    assign initial_audio_mode = 'voice_music'
  elsif normalized_audio_value contains 'chanson'
    assign initial_audio_mode = 'ai'
  elsif normalized_audio_value contains 'musique composee'
    assign initial_audio_mode = 'ai'
  elsif normalized_audio_value contains 'musique composée'
    assign initial_audio_mode = 'ai'
  elsif normalized_audio_value contains 'ia'
    assign initial_audio_mode = 'ai'
  elsif normalized_audio_value contains 'enregistrement' or normalized_audio_value contains 'voix' or normalized_audio_value contains 'message'
    assign initial_audio_mode = 'voice'
  endif

  assign next_step_text = "Ajoutez d'abord votre souvenir au panier. Vous pourrez ensuite nous transmettre les éléments utiles en quelques instants."

  if initial_audio_mode == 'voice'
    assign next_step_text = "Après l'ajout au panier, vous importerez votre fichier audio et pourrez ajouter quelques indications utiles."
  elsif initial_audio_mode == 'ai'
    assign next_step_text = "Après l'ajout au panier, vous décrirez l'intention créative. Un aperçu vous sera envoyé avant production."
  elsif initial_audio_mode == 'voice_music'
    assign next_step_text = "Après l'ajout au panier, vous joindrez votre enregistrement puis le brief musical souhaité."
  endif

  assign file_group_visible = false
  assign brief_group_visible = false
  assign notes_group_visible = false

  if initial_audio_mode == 'voice' or initial_audio_mode == 'voice_music'
    assign file_group_visible = true
  endif

  if initial_audio_mode == 'ai' or initial_audio_mode == 'voice_music'
    assign brief_group_visible = true
  endif

  if initial_audio_mode != blank
    assign notes_group_visible = true
  endif
-%}

{%- if panel_group == 'secondary' -%}
  <div class="audio-keepsake-form__panel audio-keepsake-form__panel--details">
    <div class="audio-keepsake-details__section">
      <div>
        <p class="audio-keepsake-form__eyebrow">Personnalisation</p>
        <h2 class="audio-keepsake-form__title h4">Vous finaliserez les détails juste après l'ajout au panier.</h2>
      </div>
      <p class="audio-keepsake-form__lead">
        Vous choisissez d'abord le format qui vous ressemble, puis vous nous transmettez les éléments créatifs dans le
        panier, sans alourdir la décision d'achat.
      </p>
      <p class="audio-keepsake-form__helper">{{ next_step_text }}</p>
    </div>

    <div class="audio-keepsake-details__section audio-keepsake-preview__flow">
      <p class="audio-keepsake-form__eyebrow">Ce que nous vous demanderons ensuite</p>
      <div class="audio-keepsake-preview__grid">
        <article
          class="audio-keepsake-preview__group"
          data-audio-role="file"
          {% unless file_group_visible %}
            hidden
          {% endunless %}
        >
          <span class="audio-keepsake-preview__icon">01</span>
          <div>
            <h3 class="audio-keepsake-preview__group-title">Votre fichier audio</h3>
            <p class="audio-keepsake-form__helper">
              Message vocal, archive sonore, extrait enregistré sur téléphone ou tout audio que vous souhaitez confier.
            </p>
          </div>
        </article>

        <article
          class="audio-keepsake-preview__group"
          data-audio-role="brief"
          {% unless brief_group_visible %}
            hidden
          {% endunless %}
        >
          <span class="audio-keepsake-preview__icon">02</span>
          <div>
            <h3 class="audio-keepsake-preview__group-title">Votre brief créatif</h3>
            <p class="audio-keepsake-form__helper">
              L'émotion, l'histoire, les prénoms, le ton ou les souvenirs à faire ressentir dans la création.
            </p>
          </div>
        </article>

        <article
          class="audio-keepsake-preview__group"
          data-audio-role="notes"
          {% unless notes_group_visible %}
            hidden
          {% endunless %}
        >
          <span class="audio-keepsake-preview__icon">03</span>
          <div>
            <h3 class="audio-keepsake-preview__group-title">Quelques précisions si besoin</h3>
            <p class="audio-keepsake-form__helper">
              Un détail sensible, une date, une attention particulière ou une nuance à transmettre à notre équipe.
            </p>
          </div>
        </article>
      </div>
    </div>
  </div>
{%- endif -%}

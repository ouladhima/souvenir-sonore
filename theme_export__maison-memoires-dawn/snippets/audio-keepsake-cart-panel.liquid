{% comment %}
  Renders the post-add personalization panel for the audio keepsake cart line.

  Accepts:
  - item: Line item object
  - line_index: 1-based cart line index
  - line_key: Shopify line item key
  - variant_id: Variant id
  - audio_mode: voice | ai | voice_music
  - audio_option_value: Selected audio option value
  - duration_value: Selected duration option value
  - packaging_value: Selected packaging option value
{% endcomment %}
{%- liquid
  assign existing_file = item.properties['Fichier audio']
  assign existing_brief = item.properties['Brief créatif']
  assign existing_notes = item.properties['Notes complémentaires']

  assign needs_file = false
  assign needs_brief = false

  if audio_mode == 'voice' or audio_mode == 'voice_music'
    assign needs_file = true
  endif

  if audio_mode == 'ai' or audio_mode == 'voice_music'
    assign needs_brief = true
  endif

  assign line_complete = true
  if needs_file and existing_file == blank
    assign line_complete = false
  endif
  if needs_brief and existing_brief == blank
    assign line_complete = false
  endif

  assign status_label = 'À compléter'
  if line_complete
    assign status_label = 'Prêt pour la suite'
  endif
-%}

<audio-keepsake-cart-panel
  class="audio-keepsake-cart"
  data-line="{{ line_index }}"
  data-line-key="{{ line_key | escape }}"
  data-variant-id="{{ variant_id }}"
  data-quantity="{{ item.quantity }}"
  data-mode="{{ audio_mode }}"
  data-complete="{{ line_complete }}"
  data-existing-properties='{{ item.properties | json | escape }}'
  data-required-file-message="Ajoutez votre fichier audio pour continuer."
  data-required-brief-message="Décrivez votre intention pour continuer."
  data-generic-error-message="Une erreur est survenue. Réessayez dans quelques instants."
  data-success-message="Votre personnalisation a bien été enregistrée."
  data-cloudinary-cloud-name="{{ settings.cloudinary_cloud_name | escape }}"
  data-cloudinary-upload-preset="{{ settings.cloudinary_upload_preset | escape }}"
  data-upload-error-message="L'envoi du fichier a échoué. Vérifiez votre connexion et réessayez."
  data-upload-size-error-message="Le fichier est trop volumineux (max 100 Mo). Choisissez un fichier plus petit."
>
  <div class="audio-keepsake-cart__header">
    <span class="audio-keepsake-cart__status" data-status-badge>{{ status_label }}</span>
  </div>

  <div class="audio-keepsake-cart__summary">
    <div class="audio-keepsake-cart__summary-item">
      <span>Type audio</span>
      <strong>{{ audio_option_value }}</strong>
    </div>
    {%- if duration_value != blank -%}
      <div class="audio-keepsake-cart__summary-item">
        <span>Durée</span>
        <strong>{{ duration_value }}</strong>
      </div>
    {%- endif -%}
    {%- if packaging_value != blank -%}
      <div class="audio-keepsake-cart__summary-item">
        <span>Packaging</span>
        <strong>{{ packaging_value }}</strong>
      </div>
    {%- endif -%}
  </div>

  <div class="audio-keepsake-cart__fields">
    {%- if needs_file -%}
      <div class="audio-keepsake-cart__field" data-role="file">
        <div class="audio-keepsake-cart__label-row">
          <label class="audio-keepsake-cart__label" for="AudioFile-{{ line_index }}">Fichier audio</label>
        </div>
        <input
          id="AudioFile-{{ line_index }}"
          class="audio-keepsake-cart__file-input visually-hidden"
          type="file"
          accept="audio/*,.mp3,.wav,.m4a,.aac,.ogg,.flac"
          data-file-input
        >
        <label
          for="AudioFile-{{ line_index }}"
          class="audio-keepsake-cart__file-trigger"
          data-file-trigger
        >
          <span class="audio-keepsake-cart__file-trigger-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 16V4"/>
              <path d="M6 10l6-6 6 6"/>
              <path d="M4 20h16"/>
            </svg>
          </span>
          <span class="audio-keepsake-cart__file-trigger-text" data-file-trigger-label>
            {%- if existing_file != blank -%}
              Remplacer le fichier
            {%- else -%}
              Choisir un fichier audio
            {%- endif -%}
          </span>
        </label>
        <p class="audio-keepsake-cart__file-hint">MP3, WAV, M4A — 100 Mo max</p>
        <div class="audio-keepsake-cart__upload-progress" data-upload-progress hidden>
          <div class="audio-keepsake-cart__upload-bar">
            <div class="audio-keepsake-cart__upload-fill" data-upload-fill></div>
          </div>
          <span class="audio-keepsake-cart__upload-label" data-upload-label>Envoi en cours...</span>
        </div>
        <div class="audio-keepsake-cart__saved" data-file-saved-state>
          {%- if existing_file != blank -%}
            <span class="audio-keepsake-cart__saved-label">Fichier enregistré</span>
            {%- if existing_file contains 'https://' or existing_file contains 'http://' -%}
              <a href="{{ existing_file }}" class="link" target="_blank" rel="noopener">{{ existing_file | split: '/' | last | split: '?' | first }}</a>
            {%- else -%}
              <span>{{ existing_file }}</span>
            {%- endif -%}
          {%- else -%}
            <span class="audio-keepsake-cart__saved-label">Aucun fichier enregistré pour le moment</span>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if needs_brief -%}
      <div class="audio-keepsake-cart__field" data-role="brief">
        <div class="audio-keepsake-cart__label-row">
          <label class="audio-keepsake-cart__label" for="CreativeBrief-{{ line_index }}">Brief créatif pour création IA</label>
          <details class="audio-keepsake-cart__tooltip">
            <summary aria-label="Voir un exemple de brief créatif pour création IA">i</summary>
            <div class="audio-keepsake-cart__tooltip-content">
              Cliquez sur une catégorie pour afficher 3 propositions de brief, naviguez avec les flèches, puis choisissez celle qui correspond le mieux à votre intention. Le panneau se referme si vous cliquez ailleurs.
            </div>
          </details>
        </div>
        <p class="audio-keepsake-cart__helper">
          Ce brief guide la création musicale par IA : personnalisation, style, émotion, langue, voix, tempo et détails à intégrer.
        </p>

        <div class="audio-keepsake-cart__brief-templates" data-brief-template-picker aria-label="Modèles de brief pour création IA">
          <p class="audio-keepsake-cart__brief-templates-label">Choisir une inspiration</p>
          <div class="audio-keepsake-cart__brief-categories" role="tablist" aria-label="Catégories de brief créatif">
            <button type="button" role="tab" class="audio-keepsake-cart__brief-category" data-brief-category-button data-brief-category-index="0" aria-selected="false">Anniversaire</button>
            <button type="button" role="tab" class="audio-keepsake-cart__brief-category" data-brief-category-button data-brief-category-index="1" aria-selected="false">Amour</button>
            <button type="button" role="tab" class="audio-keepsake-cart__brief-category" data-brief-category-button data-brief-category-index="2" aria-selected="false">Naissance</button>
            <button type="button" role="tab" class="audio-keepsake-cart__brief-category" data-brief-category-button data-brief-category-index="3" aria-selected="false">Mariage</button>
            <button type="button" role="tab" class="audio-keepsake-cart__brief-category" data-brief-category-button data-brief-category-index="4" aria-selected="false">Hommage</button>
            <button type="button" role="tab" class="audio-keepsake-cart__brief-category" data-brief-category-button data-brief-category-index="5" aria-selected="false">Famille</button>
          </div>
          <div class="audio-keepsake-cart__brief-card" data-brief-template-card hidden>
            <div class="audio-keepsake-cart__brief-card-header">
              <span data-brief-template-label>Anniversaire</span>
              <span data-brief-template-counter>1 / 3</span>
            </div>
            <p class="audio-keepsake-cart__brief-preview" data-brief-template-preview></p>
            <div class="audio-keepsake-cart__brief-actions">
              <div class="audio-keepsake-cart__brief-nav">
                <button type="button" class="audio-keepsake-cart__brief-nav-button" data-brief-template-prev aria-label="Voir le brief précédent">‹</button>
                <button type="button" class="audio-keepsake-cart__brief-nav-button" data-brief-template-next aria-label="Voir le brief suivant">›</button>
              </div>
              <button type="button" class="audio-keepsake-cart__brief-apply" data-brief-template-apply>Utiliser ce brief</button>
            </div>
          </div>
          <template data-brief-template-data>
            <div data-brief-template-category="Anniversaire">
              <p data-brief-template-choice>Création musicale par IA pour un anniversaire. Personne célébrée : [Nom à compléter]. Relation : [à compléter]. Style musical souhaité : R&amp;B doux / pop française élégante / piano voix. Ambiance : chaleureuse, intime et lumineuse. Mots ou souvenirs à intégrer : [à compléter]. Éviter : [à compléter].</p>
              <p data-brief-template-choice>Chanson personnalisée par IA pour [Nom à compléter], anniversaire de [âge à compléter]. Style : rap FR mélodique / RNB / afro-pop douce. Ton : complice, positif, avec refrain mémorable. Détails à intégrer : [surnom, ville, souvenir, date]. Langue : français.</p>
              <p data-brief-template-choice>Musique IA premium pour surprendre [Nom à compléter]. Univers : balade cinématique / soul moderne / pop acoustique. Émotion : gratitude et tendresse. Message central : [à compléter]. Niveau d'énergie : doux / moyen / festif. Voix souhaitée : [féminine / masculine / duo].</p>
            </div>
            <div data-brief-template-category="Amour">
              <p data-brief-template-choice>Création musicale par IA pour [Nom à compléter], message d'amour de [Votre nom à compléter]. Style : R&amp;B intime / pop piano / soul moderne. Ambiance : tendre, élégante, légèrement nostalgique. Souvenir à intégrer : [à compléter]. Phrase importante à reprendre : [à compléter].</p>
              <p data-brief-template-choice>Chanson IA romantique pour [Nom à compléter]. Style musical : rap US doux / RNB slow / pop française. Ton : sincère, adulte, sans paroles trop clichées. Rythme : lent à moyen. Détails personnels : [rencontre, lieu, date, surnom]. Émotion finale : [à compléter].</p>
              <p data-brief-template-choice>Musique personnalisée IA pour déclarer ou remercier [Nom à compléter]. Univers : voix chaude, arrangement minimal, basse douce, refrain facile à retenir. Langue : français avec quelques mots en [anglais / espagnol / autre]. Mots à éviter : [à compléter].</p>
            </div>
            <div data-brief-template-category="Naissance">
              <p data-brief-template-choice>Création musicale par IA pour une naissance. Prénom du bébé : [Nom à compléter]. Prénoms des parents : [à compléter]. Style : berceuse moderne / piano doux / pop acoustique. Ambiance : apaisante, lumineuse, protectrice. Détails à intégrer : date, heure ou lieu de naissance : [à compléter].</p>
              <p data-brief-template-choice>Chanson IA douce pour accueillir [Nom à compléter]. Style musical : folk délicat / R&amp;B très doux / comptine premium. Voix : tendre et rassurante. Tempo : lent. Message central : bienvenue, amour, promesse de présence. Personnes à mentionner : [à compléter].</p>
              <p data-brief-template-choice>Musique personnalisée par IA pour offrir à de jeunes parents. Bébé : [Nom à compléter]. Style : pop française élégante / piano voix / ambient chaleureux. Ton : délicat, jamais trop enfantin. Souvenir ou anecdote familiale à intégrer : [à compléter].</p>
            </div>
            <div data-brief-template-category="Mariage">
              <p data-brief-template-choice>Création musicale par IA pour un mariage. Prénoms : [Nom à compléter] et [Nom à compléter]. Style : balade cinématique / pop orchestrale / soul élégante. Ambiance : solennelle, lumineuse, émouvante. Date et lieu : [à compléter]. Histoire ou symbole à intégrer : [à compléter].</p>
              <p data-brief-template-choice>Chanson IA pour ouverture de coffret de mariage. Couple : [Noms à compléter]. Style musical : piano voix / R&amp;B élégant / pop française. Ton : intime, pas trop grandiloquent. Refrain autour de : [phrase ou idée à compléter]. Voix souhaitée : [à compléter].</p>
              <p data-brief-template-choice>Musique personnalisée IA pour célébrer [Nom à compléter] et [Nom à compléter]. Énergie : douce puis crescendo. Instruments souhaités : piano, cordes, basse légère, percussions discrètes. Souvenirs à intégrer : [rencontre, voyage, promesse]. Mots à éviter : [à compléter].</p>
            </div>
            <div data-brief-template-category="Hommage">
              <p data-brief-template-choice>Création musicale par IA en hommage à [Nom à compléter]. Style : piano voix / orchestration douce / chanson française sobre. Ambiance : apaisée, digne, chaleureuse, sans pathos excessif. Souvenir ou qualité à évoquer : [à compléter]. Personnes destinataires : [à compléter].</p>
              <p data-brief-template-choice>Musique IA de mémoire pour [Nom à compléter]. Ton : recueilli et lumineux. Style musical : soul douce / folk acoustique / ambient cinématique. Tempo : lent. Mots importants : [à compléter]. Éviter : [éléments sensibles à compléter].</p>
              <p data-brief-template-choice>Chanson personnalisée par IA pour garder une présence. Prénom : [Nom à compléter]. Relation : [à compléter]. Souvenirs à intégrer : [voix, lieu, phrase, rituel]. Style : français poétique, instrumentation minimale, voix chaleureuse. Émotion recherchée : [à compléter].</p>
            </div>
            <div data-brief-template-category="Famille">
              <p data-brief-template-choice>Création musicale par IA pour [Nom à compléter], offerte par la famille. Style : pop française douce / RNB chaleureux / folk lumineux. Ambiance : gratitude, transmission, complicité. Prénoms à mentionner : [à compléter]. Souvenirs communs : [à compléter].</p>
              <p data-brief-template-choice>Chanson IA pour maman, papa ou grand-parent. Destinataire : [Nom à compléter]. Style musical : chanson française moderne / piano voix / soul douce. Ton : élégant, tendre, sincère. Message central : merci pour [à compléter]. Détails personnels : [surnom, maison, ville, phrase familiale].</p>
              <p data-brief-template-choice>Musique personnalisée par IA pour une fratrie ou un groupe. Prénoms : [Noms à compléter]. Style : rap FR positif / pop entraînante / afro-pop douce. Énergie : joyeuse mais raffinée. Souvenirs, blagues privées ou expressions à intégrer : [à compléter].</p>
            </div>
          </template>
        </div>

        <textarea
          id="CreativeBrief-{{ line_index }}"
          class="audio-keepsake-cart__input audio-keepsake-cart__input--textarea"
          rows="6"
          placeholder="Décrivez le destinataire, les prénoms, le contexte, le style musical souhaité, la voix, l'ambiance, les mots à intégrer et les éléments à éviter."
          data-brief-input
        >{{ existing_brief }}</textarea>
      </div>
    {%- endif -%}

    <div class="audio-keepsake-cart__field">
      <div class="audio-keepsake-cart__label-row">
        <label class="audio-keepsake-cart__label" for="AdditionalNotes-{{ line_index }}">Notes</label>
        <details class="audio-keepsake-cart__tooltip">
          <summary aria-label="Voir un exemple de notes complémentaires">i</summary>
          <div class="audio-keepsake-cart__tooltip-content">
            Exemple : éviter une voix trop solennelle, mentionner la date du 12 juin, garder un ton intime et rassurant.
          </div>
        </details>
      </div>
      <textarea
        id="AdditionalNotes-{{ line_index }}"
        class="audio-keepsake-cart__input audio-keepsake-cart__input--textarea audio-keepsake-cart__input--compact"
        rows="4"
        placeholder="Ajoutez ici un contexte utile, une date importante, une contrainte ou une attention particulière."
        data-notes-input
      >{{ existing_notes }}</textarea>
    </div>
  </div>

  <div class="audio-keepsake-cart__footer">
    <p class="audio-keepsake-cart__message" data-form-message hidden></p>
    <button type="button" class="button audio-keepsake-cart__save-btn" data-save-button>
      {%- if line_complete -%}
        Mettre à jour
      {%- else -%}
        Enregistrer
      {%- endif -%}
    </button>
  </div>
</audio-keepsake-cart-panel>
